class HitRatePercentage(RootModel[float]):
    root: float
    def __float__(self) -> float: ...
    @override
    def __hash__(self) -> int: ...
    @override
    def __eq__(self, other: object) -> bool: ...
    def __lt__(self, other: float | HitRatePercentage) -> bool: ...
