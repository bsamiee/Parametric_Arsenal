    @override
    def __eq__(self, other: object) -> bool: ...
    def __add__(self, other: int | EntryCount) -> EntryCount: ...
    def __sub__(self, other: int | EntryCount) -> EntryCount: ...
    def __iadd__(self, other: int | EntryCount) -> Self: ...
    def __isub__(self, other: int | EntryCount) -> Self: ...
    def __lt__(self, other: int | EntryCount | MaxEntries) -> bool: ...
    def __le__(self, other: int | EntryCount | MaxEntries) -> bool: ...
    def __gt__(self, other: int | EntryCount | MaxEntries) -> bool: ...
    def __ge__(self, other: int | EntryCount | MaxEntries) -> bool: ...

