    def __gt__(self, other: float | HitRatePercentage) -> bool: ...
    def __ge__(self, other: float | HitRatePercentage) -> bool: ...
    def __add__(self, other: float | HitRatePercentage) -> HitRatePercentage: ...
    def __sub__(self, other: float | HitRatePercentage) -> HitRatePercentage: ...
    def __mul__(self, other: float) -> HitRatePercentage: ...
    def __truediv__(self, other: float | HitRatePercentage) -> float: ...

