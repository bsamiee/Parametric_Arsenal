from typing import Self, override

from pydantic import RootModel

# --- String-based aliases (from PrimStr) --------------------------------------

class CacheKey(RootModel[str]):
    root: str
    def __len__(self) -> int: ...
    @override
    def __hash__(self) -> int: ...
    @override
    def __eq__(self, other: object) -> bool: ...
    def __lt__(self, other: CacheKey | str) -> bool: ...
    def __le__(self, other: CacheKey | str) -> bool: ...
    def __gt__(self, other: CacheKey | str) -> bool: ...
    def __ge__(self, other: CacheKey | str) -> bool: ...
    def __contains__(self, item: str) -> bool: ...
    def startswith(self, prefix: str) -> bool: ...
    def endswith(self, suffix: str) -> bool: ...

class CacheNamespace(RootModel[str]):
    root: str
    def __len__(self) -> int: ...
    @override
    def __hash__(self) -> int: ...
    @override
    def __eq__(self, other: object) -> bool: ...

class KeyPattern(RootModel[str]):
    root: str
    def __len__(self) -> int: ...

class RedisConnectionURL(RootModel[str]):
    root: str

