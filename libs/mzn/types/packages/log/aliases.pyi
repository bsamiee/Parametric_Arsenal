from collections.abc import Generator, ItemsView, KeysView, ValuesView
from typing import Any, override
from uuid import UUID

from pydantic import RootModel

class LoggerName(RootModel[str]):
    root: str

    # From CastingMixin (casting=True)
    def __int__(self) -> int: ...
    def __float__(self) -> float: ...
    def __bytes__(self) -> bytes: ...

class LogMessage(RootModel[str]):
    root: str

    # From CastingMixin (casting=True)
    def __int__(self) -> int: ...
    def __float__(self) -> float: ...
    def __bytes__(self) -> bytes: ...

    # From ContainerMixin (container=True)
    def __len__(self) -> int: ...
    def __getitem__(self, key: object) -> object: ...
    def __contains__(self, item: object) -> bool: ...
    @override
    def __iter__(self) -> Generator[tuple[str, Any]]: ...

class LogContext(RootModel[dict[str, Any]]):
    root: dict[str, Any]

    # From ContainerMixin (container=True)
    def __len__(self) -> int: ...
    def __getitem__(self, key: str) -> object: ...
    def __contains__(self, item: object) -> bool: ...
    @override
    def __iter__(self) -> Generator[tuple[str, Any]]: ...

    # Dict-like methods from container operations
    def keys(self) -> KeysView[str]: ...
    def values(self) -> ValuesView[Any]: ...
    def items(self) -> ItemsView[str, Any]: ...

    # From CastingMixin (casting=True)
    def __int__(self) -> int: ...
    def __float__(self) -> float: ...
    def __bytes__(self) -> bytes: ...

class LogRecordID(RootModel[str]):
    root: str

    # From CastingMixin (casting=True)
    def __int__(self) -> int: ...
    def __float__(self) -> float: ...
    def __bytes__(self) -> bytes: ...

    # From PrimUUID base
    def as_uuid(self) -> UUID: ...
