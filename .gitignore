# --- Metadata -----------------------------------------------------------------
# Title           : .gitignore
# Author          : Bardia Samiee
# Project         : Parametric Arsenal

# Purpose: Keep the repository clean of OS noise, build artifacts and transient
# files while *not* ignoring domain assets that should go through Git LFS
# (e.g., *.3dm, *.gh, *.ghuser).
# ==============================================================================

# --- General -------------------------------------------------------------------
poetry.lock
todo.txt
placeholder.txt

# --- macOS & Editor cruft -----------------------------------------------------
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride

# --- Vim / Emacs / VS Code swap files -----------------------------------------
*~ # vim backup files
*.swp
*.swo
*.tmp
*.bak
*.orig

# --- Python artifacts ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments -----------------------------------------------------
.env/
.venv/
env/
venv/

# --- Packaging ----------------------------------------------------------------
build/
dist/
wheelhouse/
.eggs/
*.egg-info/
pip-wheel-metadata/

# --- Caches & reports ---------------------------------------------------------
.cache/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# --- .NET / Visual Studio / Rider artifacts -----------------------------------

# --- Build outputs --------------------------
**/bin/
**/obj/

# --- VS & Rider -----------------------------
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates


# --- Test results & coverage ----------------
TestResults/
*.coverage
*.coveragexml
*.testresults


# --- Documentation build outputs ---------------------------------------------
_site/

# --- Node (occasionally used for docs scripts) --------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Logs ---------------------------------------------------------------------
*.log

# ------------------------------------------------------------------------------
# Leave Rhino / Grasshopper assets *tracked* via Git LFS
#   *.3dm
#   *.gh
#   *.ghuser
# (Handled by .gitattributes - do NOT ignore them here)